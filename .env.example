# Vault Manager Keypair (base58 encoded private key)
MANAGER_PRIVATE_KEY=

# RPC endpoint (Helius recommended for reliability)
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Strategy Parameters
TARGET_LEVERAGE=1.0
MAX_POSITION_SIZE_USDC=50000
REBALANCE_THRESHOLD_PCT=5
FUNDING_RATE_MIN_APY=5
STOP_LOSS_PCT=3
